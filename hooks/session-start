#!/usr/bin/env bash
# SessionStart hook for specpowers plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

SKILLS_ROOT="${PLUGIN_ROOT}/.claude/skills"
USING_SKILLS_PATH="${SKILLS_ROOT}/using-skills/SKILL.md"

# Claude Code plugin installs use the managed .claude/skills payload generated
# from manifests/install-modules.json. Do not fall back to the source skills/
# tree here; that bypasses the install manifest and can expose unsupported
# skills that were not selected for the plugin payload.
if [ -f "$USING_SKILLS_PATH" ]; then
    using_skills_content=$(cat "$USING_SKILLS_PATH")
else
    using_skills_content="Error: SpecPowers managed Claude Code skills were not found at ${USING_SKILLS_PATH}. Run: node scripts/install.js --platform claude-code --profile developer"
fi

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_skills_escaped=$(escape_for_json "$using_skills_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have specpowers.\n\n**Below is the full content of your 'specpowers:using-skills' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_skills_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
